{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dataset Schema",
  "description": "Schema for datasets registered in EKC, representing logical units of curated content used as input to generation.",
  "type": "object",
  "required": ["datasetId", "version", "sourceRef", "metadata"],
  "properties": {
    "datasetId": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$",
      "description": "Unique dataset identifier (lowercase alphanumeric and hyphens)."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Semantic version of dataset."
    },
    "sourceRef": {
      "type": "string",
      "description": "Reference to Source Registry entry (e.g., source:wikipedia:v1)."
    },
    "metadata": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable dataset title."
        },
        "description": {
          "type": "string",
          "description": "Dataset description and scope."
        },
        "author": {
          "type": "string",
          "description": "Author or curator of dataset."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When dataset was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When dataset was last updated."
        }
      }
    },
    "contentPointers": {
      "type": "array",
      "description": "Pointers to source content (paths, URLs, or references).",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relative path or reference to content."
          },
          "type": {
            "type": "string",
            "description": "Content type (e.g., markdown, json, html)."
          },
          "checksum": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$",
            "description": "Optional checksum of content for verification."
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Classification tags."
    },
    "provenance": {
      "type": "object",
      "description": "Provenance and sourcing info.",
      "properties": {
        "sourceUrl": {
          "type": "string",
          "format": "uri",
          "description": "Original source URL (if applicable)."
        },
        "license": {
          "type": "string",
          "description": "License of source content."
        },
        "attribution": {
          "type": "string",
          "description": "Attribution requirements."
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "archived", "deprecated"],
      "description": "Status of dataset."
    }
  },
  "additionalProperties": false
}
